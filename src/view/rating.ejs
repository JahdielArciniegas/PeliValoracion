<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Calificar Película</title>
    <style>
        /* --- ESTILOS EN BASE A LA APLICACIÓN INICIAL --- */
        :root {
            --primary-color: #4f46e5;
            --primary-hover: #4338ca;
            --bg-color: #f3f4f6;
            --text-color: #1f2937;
            --card-bg: #ffffff;
            --gray-light: #e5e7eb;
            --gray-text: #6b7280;
            --star-color: #fbbf24;
            --success-color: #10b981;
        }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--bg-color);
            display: flex;
            justify-content: center;
            align-items: flex-start;
            min-height: 100vh;
            margin: 0;
            padding: 2rem 1rem;
            box-sizing: border-box;
        }
        .rating-container {
            background-color: var(--card-bg);
            padding: 2.5rem 2rem;
            border-radius: 12px;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
            width: 100%;
            max-width: 600px;
            text-align: center;
        }
        .movie-header {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 1rem;
            margin-bottom: 2rem;
        }
        .movie-poster-preview {
            width: 150px;
            height: 225px;
            border-radius: 8px;
            object-fit: cover;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            background-color: #e0e7ff;
        }
        h2.movie-title {
            color: var(--text-color);
            margin: 0;
            font-size: 1.5rem;
        }
        /* --- Panel de Estado de Calificaciones --- */
        .status-panel {
            background-color: var(--bg-color);
            border-radius: 8px;
            padding: 1rem;
            margin-bottom: 2rem;
            text-align: left;
            border-left: 4px solid var(--primary-color);
        }
        .status-title {
            font-weight: 600;
            color: var(--text-color);
            margin-bottom: 0.5rem;
            font-size: 0.95rem;
        }
        .status-text {
            color: var(--gray-text);
            font-size: 0.9rem;
            margin: 0;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .status-badge {
            padding: 3px 8px;
            border-radius: 12px;
            font-size: 0.8rem;
            font-weight: 600;
        }
        .badge-none { background-color: #fee2e2; color: #ef4444; }
        .badge-partial { background-color: #fef3c7; color: #d97706; }
        .badge-full { background-color: #d1fae5; color: #10b981; }
        
        /* --- Reseñas de la Pareja --- */
        .reviews-section {
            margin-top: 2rem;
            text-align: left;
            border-top: 1px solid var(--gray-light);
            padding-top: 1.5rem;
            display: none; /* Se visualiza sólo si existen reseñas */
        }
        .reviews-title {
            font-size: 1.1rem;
            color: var(--text-color);
            margin-bottom: 1rem;
            font-weight: 700;
        }
        .review-card {
            background-color: var(--bg-color);
            border-radius: 8px;
            padding: 1rem;
            margin-bottom: 1rem;
            border-left: 4px solid var(--gray-light);
        }
        .review-card.partner {
            border-left-color: #ec4899; /* Rosa para la pareja */
            background-color: #fdf2f8;
        }
        .review-card.me {
            border-left-color: var(--primary-color); /* Azul para ti */
            background-color: #eef2ff;
        }
        .review-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 0.5rem;
        }
        .review-author {
            font-weight: 600;
            color: var(--text-color);
            font-size: 0.9rem;
        }
        .review-stars {
            color: var(--star-color);
            font-size: 1rem;
            letter-spacing: 1px;
        }
        .review-text {
            color: var(--gray-text);
            font-size: 0.9rem;
            margin: 0;
            line-height: 1.4;
        }
        /* --- Formulario y Estrellas --- */
        .stars-container {
            display: flex;
            flex-direction: row-reverse;
            justify-content: center;
            gap: 0.25rem;
            margin-bottom: 1.5rem;
        }
        .stars-container input { display: none; }
        .stars-container label {
            font-size: 2.8rem;
            color: var(--gray-light);
            cursor: pointer;
            transition: color 0.2s;
        }
        .stars-container label:hover,
        .stars-container label:hover ~ label,
        .stars-container input:checked ~ label {
            color: var(--star-color);
        }
        .form-group {
            margin-bottom: 1.5rem;
            text-align: left;
        }
        label.field-label {
            display: block;
            margin-bottom: 0.5rem;
            color: var(--text-color);
            font-size: 0.9rem;
            font-weight: 600;
        }
        textarea {
            width: 100%;
            padding: 0.75rem;
            border: 1px solid var(--gray-light);
            border-radius: 6px;
            box-sizing: border-box;
            font-family: inherit;
            resize: vertical;
            min-height: 100px;
            font-size: 0.95rem;
        }
        textarea:focus {
            outline: none;
            border-color: var(--primary-color);
            box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.1);
        }
        .btn-submit {
            width: 100%;
            padding: 0.8rem;
            background-color: var(--primary-color);
            color: white;
            border: none;
            border-radius: 6px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: background-color 0.2s;
        }
        .btn-submit:hover { background-color: var(--primary-hover); }
        .btn-submit:disabled { background-color: var(--gray-light); cursor: not-allowed; }
        
        .btn-return {
            display: inline-block;
            margin-top: 1.5rem;
            color: var(--gray-text);
            text-decoration: none;
            font-size: 0.9rem;
            transition: color 0.2s;
        }
        .btn-return:hover { color: var(--text-color); }
        .feedback-message {
            margin-top: 1rem;
            font-weight: 600;
            font-size: 0.9rem;
            display: none;
            padding: 0.8rem;
            border-radius: 6px;
        }
        .alert-error { background-color: #fee2e2; color: #ef4444; }
        .alert-success { background-color: #d1fae5; color: #10b981; }
        /* Spinner de carga inicial */
        #loading-view { padding: 3rem; color: var(--gray-text); font-style: italic; }
        #content-view { display: none; }
    </style>
</head>
<body>
    <!-- Variables extraidas de la sesión y URL (EJS) -->
    <input type="hidden" id="coupleId" value="<%= session.user.user.coupleId %>">
    <input type="hidden" id="userId" value="<%= session.user.user.id %>">
    <input type="hidden" id="movieId" value="<%= movieId %>">
    <div class="rating-container">
        <!-- Vista de Carga -->
        <div id="loading-view">Cargando información de la película...</div>
        <!-- Contenido Real -->
        <div id="content-view">
            <div class="movie-header">
                <img id="movie-poster" class="movie-poster-preview" src="" alt="Poster" style="display: none;">
                <h2 id="movie-title" class="movie-title">Cargando...</h2>
            </div>
            <!-- Panel informativo sobre si la pareja ya calificó -->
            <div class="status-panel">
                <div class="status-title">Estado de la Calificación</div>
                <div id="rating-status-text" class="status-text">
                    <span class="status-badge badge-none">Sin calificar</span>
                    Ninguno ha calificado esta película aún.
                </div>
            </div>
            <!-- Sección de visualización de opiniones mutuas -->
            <div id="reviews-section" class="reviews-section">
                <div class="reviews-title">Nuestras Opiniones</div>
                <div id="reviews-list"></div>
            </div>
            <!-- Formulario de Calificación -->
            <form id="ratingForm">
                <div class="stars-container">
                    <input type="radio" id="star10" name="rating" value="10">
                    <label for="star10" title="10 estrellas">★</label>
                    <input type="radio" id="star9" name="rating" value="9">
                    <label for="star9" title="9 estrellas">★</label>
                    <input type="radio" id="star8" name="rating" value="8">
                    <label for="star8" title="8 estrellas">★</label>
                    <input type="radio" id="star7" name="rating" value="7">
                    <label for="star7" title="7 estrellas">★</label>
                    <input type="radio" id="star6" name="rating" value="6">
                    <label for="star6" title="6 estrellas">★</label>
                    <input type="radio" id="star5" name="rating" value="5">
                    <label for="star5" title="5 estrellas">★</label>
                    <input type="radio" id="star4" name="rating" value="4">
                    <label for="star4" title="4 estrellas">★</label>
                    <input type="radio" id="star3" name="rating" value="3">
                    <label for="star3" title="3 estrellas">★</label>
                    <input type="radio" id="star2" name="rating" value="2">
                    <label for="star2" title="2 estrellas">★</label>
                    <input type="radio" id="star1" name="rating" value="1">
                    <label for="star1" title="1 estrella">★</label>
                </div>
                <div class="form-group">
                    <label class="field-label" for="opinion">Tu opinión (se compartirá con tu pareja)</label>
                    <textarea id="opinion" name="opinion" placeholder="Opcional: Me pareció una excelente película por..." ></textarea>
                </div>
                <button type="submit" id="submit-btn" class="btn-submit">Enviar Calificación</button>
                <div id="form-feedback" class="feedback-message"></div>
                
                <a href="/coupleMovies" class="btn-return">← Volver a nuestras películas</a>
            </form>
        </div>
    </div>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            fetchMovieData();
        });
        // Extraer IDs necesarios
        const coupleId = document.getElementById('coupleId').value;
        const userId = document.getElementById('userId').value;
        
        // Obtener el ID de la película desde la variable enviada por backend en el render
        const movieId = document.getElementById('movieId').value; 
        
        // Referencias a elementos del DOM
        const loadingView = document.getElementById('loading-view');
        const contentView = document.getElementById('content-view');
        const ratingForm = document.getElementById('ratingForm');
        const feedbackMsg = document.getElementById('form-feedback');
        const submitBtn = document.getElementById('submit-btn');
        // Función para cargar los datos de la película y el estado de los ratings
        async function fetchMovieData() {
            try {
                // Hacer petición GET a la ruta indicada: /api/coupleMovie/:idcouple/:id
                const response = await fetch(`/api/coupleMovie/${coupleId}/${movieId}`);
                if (!response.ok) throw new Error('Error al obtener la película');
                
                const movie  = await response.json();
                // Actualizar UI con datos de la película
                document.getElementById('movie-title').textContent = movie.movieName || 'Película Desconocida';
                
                if (movie.moviePoster) {
                    const posterImg = document.getElementById('movie-poster');
                    posterImg.src = `https://image.tmdb.org/t/p/w500${movie.moviePoster}`;
                    posterImg.style.display = 'block';
                }
                
                // Analizar calificaciones previas
                const ratings = movie.ratings || [];
                updateStatusPanel(ratings);
                renderReviews(ratings);
                
                // Mostrar contenido
                loadingView.style.display = 'none';
                contentView.style.display = 'block';
            } catch (error) {
                console.error(error);
                loadingView.textContent = 'Hubo un error al cargar la información de la película.';
                loadingView.style.color = '#ef4444';
            }
        }
        // Función para actualizar el badge y texto informativo
        function updateStatusPanel(ratings) {
            const statusText = document.getElementById('rating-status-text');
            const totalRatings = ratings.length;
            // Verificar si el usuario actual ya calificó
            const userAlreadyRated = ratings.some(rating => rating.userId === userId);
            
            if (totalRatings === 0) {
                statusText.innerHTML = `<span class="status-badge badge-none">Sin calificar</span> Ninguno de los dos ha calificado esta película aún.`;
            } else if (totalRatings === 1) {
                if (userAlreadyRated) {
                    statusText.innerHTML = `<span class="status-badge badge-partial">Falta tu pareja</span> Tú ya calificaste esta película. Esperando a tu pareja.`;
                    disableForm();
                } else {
                    statusText.innerHTML = `<span class="status-badge badge-partial">Faltas tú</span> Tu pareja ya calificó esta película. ¡Es tu turno!`;
                }
            } else if (totalRatings >= 2) {
                statusText.innerHTML = `<span class="status-badge badge-full">¡Completado!</span> Ambos han dado su opinión sobre esta película.`;
                disableForm();
            }
        }
        
        // Renderizar las reviews (Tanto la del usuario como la de su pareja)
        function renderReviews(ratings) {
            const reviewsSection = document.getElementById('reviews-section');
            const reviewsList = document.getElementById('reviews-list');
            reviewsList.innerHTML = '';
            
            if (ratings.length === 0) {
                reviewsSection.style.display = 'none';
                return;
            }
            // Habilitar visualización de la sección si hay al menos una reseña
            reviewsSection.style.display = 'block';
            
            ratings.forEach(r => {
                const isMe = r.userId === userId;
                
                // Generar representación visual de calificación de 10 estrellas máx
                const ratingCount = Math.round(r.rating) || 0;
                const starsHtml = '★'.repeat(ratingCount) + '☆'.repeat(10 - ratingCount);
                
                // Generación de la tarjeta iterativa indicando de quién es
                const card = document.createElement('div');
                card.className = `review-card ${isMe ? 'me' : 'partner'}`;
                card.innerHTML = `
                    <div class="review-header">
                        <span class="review-author">${isMe ? 'Mi Reseña' : 'Reseña de mi Pareja 💖'}</span>
                        <span class="review-stars" title="${r.rating}/10">${starsHtml} <span style="color:#6b7280; font-size:0.8rem;">(${r.rating})</span></span>
                    </div>
                    ${r.opinion 
                        ? `<p class="review-text">"${r.opinion}"</p>` 
                        : '<p class="review-text" style="font-style:italic">No escribió ninguna reseña.</p>'
                    }
                `;
                reviewsList.appendChild(card);
            });
        }
        function disableForm() {
            submitBtn.disabled = true;
            submitBtn.textContent = 'Ya calificada / Actualización inhabilitada';
            
            // Ocultamos el formulario entero en su lugar para simplificar y dar espacio a las revisiones
            ratingForm.style.display = 'none';
        }
        // Manejo del POST para enviar la puntuación
        ratingForm.addEventListener('submit', async (event) => {
            event.preventDefault();
            feedbackMsg.style.display = 'none';
            feedbackMsg.className = 'feedback-message';
            // Validar estrellas
            const checkedStar = document.querySelector('input[name="rating"]:checked');
            if (!checkedStar) {
                feedbackMsg.textContent = 'Por favor, selecciona una puntuación de 1 a 10 estrellas.';
                feedbackMsg.classList.add('alert-error');
                feedbackMsg.style.display = 'block';
                return;
            }
            const ratingValue = Number(checkedStar.value);
            const opinionText = document.getElementById('opinion').value.trim();
            try {
                const response = await fetch(`/api/coupleMovie/${coupleId}/rate/${movieId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                        rating: ratingValue, 
                        opinion: opinionText,
                        userId: userId 
                    })
                });
                if (!response.ok) {
                    const errorData = await response.json();
                    throw new Error(errorData.message || 'Error al guardar la calificación');
                }
                // Éxito
                feedbackMsg.textContent = '¡Tu calificación ha sido guardada con éxito!';
                feedbackMsg.classList.add('alert-success');
                feedbackMsg.style.display = 'block';
                // Recargar estado actual (o redirigir)
                setTimeout(() => {
                    fetchMovieData(); // Refresca para ver el estado actualizado
                }, 1500);
            } catch (error) {
                console.error(error);
                feedbackMsg.textContent = error.message;
                feedbackMsg.classList.add('alert-error');
                feedbackMsg.style.display = 'block';
            }
        });
    </script>
</body>
</html>