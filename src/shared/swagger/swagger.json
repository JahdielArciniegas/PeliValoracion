{
  "openapi": "3.0.1",
  "info": {
    "title": "PeliValoración API",
    "description": "API para la calificación de películas y series con la persona más especial de tu vida",
    "contact": { "email": "arciniegasjahdiel@gmail.com" },
    "version": "1.0.0"
  },
  "servers": [{ "url": "https://peli-valoracion.vercel.app/api" }],
  "tags": [
    { "name": "auth", "description": "Autenticación de los usuarios" },
    { "name": "user", "description": "Operaciones acerca de los usuarios" },
    { "name": "couple", "description": "Operaciones acerca de las parejas" },
    {
      "name": "coupleMovie",
      "description": "Operaciones acerca de las películas de las parejas"
    },
    { "name": "movie", "description": "Operaciones generales de películas" }
  ],
  "paths": {
    "/auth/login": {
      "post": {
        "tags": ["auth"],
        "summary": "Login de un usuario",
        "operationId": "login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AuthResponse" }
              }
            }
          },
          "400": [
            { "description": "User should not have a session" },
            { "description": "Email and password are required" }
          ],
          "401": { "description": "Credenciales inválidas" },
          "404": { "description": "User not found" },
          "500": { "description": "Internal server error" }
        }
      }
    },
    "/auth/register": {
      "post": {
        "tags": ["auth"],
        "summary": "Registro de un usuario",
        "operationId": "register",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/User" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Usuario creado",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AuthResponse" }
              }
            }
          },
          "400": [
            {
              "description": "User should not have a session"
            },
            {
              "description": "Name, email and password are required"
            },
            {
              "description": "User already exists"
            }
          ],
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "tags": ["auth"],
        "summary": "Logout de un usuario",
        "responses": {
          "200": {
            "description": "Logout exitoso"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/user/{id}": {
      "put": {
        "tags": ["user"],
        "summary": "Actualizar usuario",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/User" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Usuario actualizado",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/User" }
              }
            }
          },
          "400": [
            { "description": "Email is required" },
            { "description": "User name is required" }
          ],
          "401": [{ "description": "Id is required for update" }],
          "404": { "description": "User not found" },
          "500": { "description": "Internal server error" }
        }
      },
      "delete": {
        "tags": ["user"],
        "summary": "Eliminar usuario",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Usuario eliminado"
          },
          "400": { "description": "User ID is not valid" },
          "401": { "description": "Id is required for remove" },
          "404": { "description": "User not found" },
          "500": { "description": "Internal server error" }
        }
      }
    },
    "/couple/code": {
      "post": {
        "tags": ["couple"],
        "summary": "Obtener código de vinculación para el usuario",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "id": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Código obtenido",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Couple" }
              }
            }
          },
          "400": [
            { "description": "User ID is not valid" },
            { "description": "User already has a couple" }
          ],
          "404": { "description": "User not found" },
          "500": { "description": "Internal server error" }
        }
      }
    },
    "/couple/code/validate": {
      "put": {
        "tags": ["couple"],
        "summary": "Validar y vincular pareja",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "id": { "type": "string" },
                  "userId": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Vinculación exitosa",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Couple" }
              }
            }
          },
          "400": [
            { "description": "IDs are not valid" },
            { "description": "Couple is full" }
          ],
          "404": [
            { "description": "Couple not found" },
            { "description": "User not found" }
          ],
          "500": { "description": "Error updating couple" }
        }
      }
    },
    "/couple/{id}": {
      "get": {
        "tags": ["couple"],
        "summary": "Obtener info de la pareja",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Datos de la pareja",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Couple" }
              }
            }
          },
          "400": { "description": "Couple ID is not valid" }
        }
      },
      "put": {
        "tags": ["couple"],
        "summary": "Cambiar nombre de la pareja",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": { "name": { "type": "string" } }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Nombre actualizado",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Couple" }
              }
            }
          },
          "400": [
            { "description": "Couple ID is not valid" },
            { "description": "Couple name is required" },
            { "description": "Couple name must be at least 3 characters long" }
          ]
        }
      },
      "delete": {
        "tags": ["couple"],
        "summary": "Eliminar pareja",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Pareja eliminada",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Couple" }
              }
            }
          },
          "400": { "description": "Couple ID is not valid" },
          "404": { "description": "Couple not found" }
        }
      }
    },
    "/coupleMovie": {
      "post": {
        "tags": ["coupleMovie"],
        "summary": "Marcar película como vista",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "coupleId": { "type": "string" },
                  "movieId": { "type": "string" },
                  "movieName": { "type": "string" },
                  "moviePoster": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Película marcada como vista"
          },
          "400": [
            { "description": "IDs are not valid" },
            { "description": "Invalid movie data" },
            { "description": "Movie already watched" }
          ],
          "404": { "description": "Couple not found" },
          "500": { "description": "Error marking movie as watched" }
        }
      }
    },
    "/coupleMovie/{coupleId}": {
      "get": {
        "tags": ["coupleMovie"],
        "summary": "Listar todas las películas vistas por la pareja",
        "parameters": [
          {
            "name": "coupleId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de películas",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/MovieWatched"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Couple ID is not valid"
          }
        }
      }
    },
    "/coupleMovie/{coupleId}/{movieId}": {
      "get": {
        "tags": ["coupleMovie"],
        "summary": "Obtener una película vista por la pareja",
        "parameters": [
          {
            "name": "coupleId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "movieId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Película obtenida exitosamente",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MovieWatched" }
              }
            }
          },
          "400": { "description": "Couple ID is not valid" }
        }
      }
    },
    "/coupleMovie/{coupleId}/{movieId}/rating": {
      "post": {
        "tags": ["coupleMovie"],
        "summary": "Calificar una película vista",
        "parameters": [
          {
            "name": "coupleId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "movieId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "rating": { "type": "number" },
                  "opinion": { "type": "string" },
                  "userId": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Calificación guardada" },
          "400": [
            { "description": "IDs are not valid" },
            { "description": "User already rated this movie" },
            { "description": "Invalid rating data" },
            { "description": "Rating must be between 1 and 10" },
            { "description": "Movie must have at least 2 ratings" }
          ],
          "404": { "description": "Movie not found" }
        }
      }
    },
    "/movies/search": {
      "get": {
        "tags": ["movie"],
        "summary": "Buscar películas por texto",
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": { "200": { "description": "Resultados de búsqueda" } }
      }
    },
    "/movies/now-playing": {
      "get": {
        "tags": ["movie"],
        "summary": "Películas actualmente en cartelera",
        "responses": { "200": { "description": "Listado exitoso" } }
      }
    },
    "/movies/popular": {
      "get": {
        "tags": ["movie"],
        "summary": "Películas más populares",
        "responses": { "200": { "description": "Listado exitoso" } }
      }
    }
  },
  "components": {
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "email": { "type": "string" },
          "role": { "type": "string" },
          "password": { "type": "string", "writeOnly": true }
        }
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "token": { "type": "string" },
          "user": { "$ref": "#/components/schemas/User" }
        }
      },
      "Couple": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "users": { "type": "array", "items": { "type": "string" } }
        }
      },
      "MovieWatched": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "poster": { "type": "string" },
          "coupleId": { "type": "string" },
          "ratings": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "userId": { "type": "string" },
                "rating": { "type": "number" },
                "opinion": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
